<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ebock.mapper.ItemDeliveryOptionMapper">

    <delete id="deleteByItemId">
        delete from ebock.item_del_option
        where item_id = #{itemId}
    </delete>

    <insert id="insert">
        insert into ebock.item_del_option (item_id, delivery_optn_id)
        values
        <foreach collection="deliveryOptions" item="deliveryOptnId" separator=",">
            (#{itemId}, #{deliveryOptnId})
        </foreach>
    </insert>
</mapper>