<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ebock.mapper.ItemMapper">

    <select id="getAllItemsInfo" resultType="com.ebock.business.Item">
        select item_id,
               name,
               description,
               price,
               added_at,
               updated_at,
               sold,
               quantity,
               archived,
               category_id,
               wear_id,
               seller_cip
        from ebock.item
        where not sold and not archived
    </select>

</mapper>
