<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ebock.mapper.ItemTagMapper">
    <insert id="insert">
        INSERT INTO ebock.tag_item (item_id, tag_id)
        VALUES
        <foreach collection="tags" item="tagId" separator=",">
            (#{itemId}, #{tagId})
        </foreach>
    </insert>
</mapper>