<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ebock.mapper.ItemTagMapper">
    <delete id="deleteByItemId">
        delete from ebock.tag_item
        where item_id = #{itemId}
    </delete>

    <insert id="insert">
        insert into ebock.tag_item (item_id, tag_id)
        values
        <foreach collection="tags" item="tagId" separator=",">
            (#{itemId}, #{tagId})
        </foreach>
    </insert>
</mapper>